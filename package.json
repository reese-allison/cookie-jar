{
  "name": "cookie-jar",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:client\" \"bun run dev:server\"",
    "dev:client": "vite",
    "dev:server": "bun --watch src/server/index.ts",
    "build": "tsc -b && vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:seed": "bun run src/server/db/seed-templates.ts",
    "db:migrate:up": "dotenv -- node-pg-migrate -m src/server/db/migrations up",
    "db:migrate:down": "dotenv -- node-pg-migrate -m src/server/db/migrations down",
    "db:migrate:redo": "dotenv -- node-pg-migrate -m src/server/db/migrations redo",
    "db:migrate:create": "dotenv -- node-pg-migrate -m src/server/db/migrations create",
    "db:migrate:check": "dotenv -- node scripts/check-migrations-safe.mjs",
    "loadtest:cursors": "k6 run tests/load/cursors.js"
  },
  "dependencies": {
    "@react-spring/web": "^10.0.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "@use-gesture/react": "^10.3.1",
    "better-auth": "^1.6.4",
    "compression": "^1.8.1",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "rate-limit-redis": "^4.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "bun-types": "^1.3.12",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^29.0.2",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  }
}
